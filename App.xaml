<?xml version="1.0" encoding="UTF-8" ?>
<Application
    x:Class="Przypominajka.App"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:conv="clr-namespace:Przypominajka.Converters">

    <Application.Resources>
        <ResourceDictionary>

            <!-- Konwertery (dostępne globalnie we wszystkich stronach) -->
            <conv:BoolToColorConverter x:Key="BoolToColorConverter" />
            <conv:BoolToStringConverter x:Key="BoolToStringConverter" />
            <conv:InvertBoolConverter x:Key="InvertBoolConverter" />
            <conv:NotNullConverter x:Key="NotNullConverter" />

            <!-- Kolory aplikacji -->
            <Color x:Key="Primary">#3498DB</Color>
            <Color x:Key="PrimaryDark">#2980B9</Color>
            <Color x:Key="Secondary">#2ECC71</Color>
            <Color x:Key="Danger">#E74C3C</Color>
            <Color x:Key="Warning">#F39C12</Color>
            <Color x:Key="Muted">#95A5A6</Color>

            <!-- Style -->
            <Style TargetType="Button">
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="12,8" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
