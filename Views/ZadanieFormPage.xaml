<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Przypominajka.Views.ZadanieFormPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Przypominajka.ViewModels"
    x:DataType="vm:ZadanieFormViewModel"
    Title="{Binding Tytul}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14">

            <!-- Loader -->
            <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}"
                               HorizontalOptions="Center" />

            <!-- Nazwa -->
            <Label Text="Nazwa zadania *" FontAttributes="Bold" />
            <Entry Text="{Binding NazwaZadania}" Placeholder="Wpisz nazwę zadania" />

            <!-- Opis -->
            <Label Text="Opis (opcjonalnie)" FontAttributes="Bold" />
            <Editor Text="{Binding OpisZadania}" Placeholder="Opis zadania..." MinimumHeightRequest="80" />

            <!-- Kategoria i Seria -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <VerticalStackLayout Grid.Column="0">
                    <Label Text="Kategoria" FontAttributes="Bold" />
                    <Picker ItemsSource="{Binding Kategorie}"
                            ItemDisplayBinding="{Binding NazwaKategorii}"
                            SelectedItem="{Binding WybranaKategoria}" />
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1">
                    <Label Text="Seria" FontAttributes="Bold" />
                    <Picker ItemsSource="{Binding Serie}"
                            ItemDisplayBinding="{Binding InterwalPowtarzania}"
                            SelectedItem="{Binding WybranaSeria}" />
                </VerticalStackLayout>
            </Grid>

            <!-- Termin wykonania -->
            <Label Text="Termin wykonania *" FontAttributes="Bold" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <DatePicker Grid.Column="0" Date="{Binding TerminWykonania}" MinimumDate="2000-01-01" />
                <TimePicker Grid.Column="1" Time="{Binding TerminWykonaniaCzas}" />
            </Grid>

            <!-- Termin przypomnienia -->
            <Label Text="Termin przypomnienia *" FontAttributes="Bold" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <DatePicker Grid.Column="0" Date="{Binding TerminPrzypomnienia}" MinimumDate="2000-01-01" />
                <TimePicker Grid.Column="1" Time="{Binding TerminPrzypomnieniaCzas}" />
            </Grid>

            <!-- Interwał po terminie -->
            <Label Text="Interwał przypominania po terminie (min) *" FontAttributes="Bold" />
            <Entry Text="{Binding InterwalPrzypominaniaPoTerminie}" Keyboard="Numeric"
                   Placeholder="np. 60" />

            <!-- Przełączniki -->
            <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                <Label Grid.Column="0" Text="Oznacz jako wykonane" VerticalOptions="Center" />
                <Switch Grid.Column="1" IsToggled="{Binding StatusWykonania}" />
            </Grid>
            <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                <Label Grid.Column="0" Text="Aktywne przypomnienie" VerticalOptions="Center" />
                <Switch Grid.Column="1" IsToggled="{Binding CzyAktywnePrzypomnienie}" />
            </Grid>

            <!-- Przyciski -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,8,0,0">
                <Button Grid.Column="0" Text="💾 Zapisz" Command="{Binding ZapiszCommand}"
                        BackgroundColor="#27AE60" TextColor="White" CornerRadius="8" />
                <Button Grid.Column="1" Text="✖ Anuluj" Command="{Binding AnulujCommand}"
                        BackgroundColor="#95A5A6" TextColor="White" CornerRadius="8" />
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
